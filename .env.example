# Copy this file to .env and fill in your API key.
# Obtain a key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Optional: debounce delay in milliseconds before triggering an AI analysis
# while the hotkey is held and the cursor is stationary (default: 800).
# DEBOUNCE_MS=800

# Optional: path to a log file for troubleshooting (disabled when empty).
# HOVERMIND_LOG_FILE=hovermind.log
