# Copy this file to .env and fill in your API keys.

# --- Provider selection ------------------------------------------------------
# gemini | openai | anthropic | ollama
# Defaults to "gemini" when unset.
# AI_PROVIDER=gemini

# Optional override of the provider model (otherwise the provider default is used)
# AI_MODEL=gemini-1.5-flash

# --- API keys ---------------------------------------------------------------
# Google Gemini
# Obtain a key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# OpenAI GPT-4o Vision
# OPENAI_API_KEY=your_openai_api_key_here

# Anthropic Claude Vision
# ANTHROPIC_API_KEY=your_anthropic_api_key_here

# --- Local providers --------------------------------------------------------
# Ollama runs locally; no key required.  Ensure the daemon is running on port 11434.
# OLLAMA_HOST=http://localhost:11434

# --- Behaviour tuning -------------------------------------------------------
# Debounce delay in milliseconds before triggering an AI analysis (default: 800).
# DEBOUNCE_MS=800

# Optional: path to a log file for troubleshooting (disabled when empty).
# HOVERMIND_LOG_FILE=hovermind.log
